{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskeptic.com/schemas/bootstrap-pack-input-v1.schema.json",
  "title": "BootstrapPackInputV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workflowId", "openaiChatCompletion"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "workflowId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{1,128}$"
    },
    "openaiChatCompletion": {
      "type": "object",
      "required": ["choices"],
      "additionalProperties": true,
      "properties": {
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["message"],
            "additionalProperties": true,
            "properties": {
              "message": {
                "type": "object",
                "required": ["tool_calls"],
                "additionalProperties": true,
                "properties": {
                  "tool_calls": {
                    "type": "array",
                    "items": {
                      "$ref": "https://agentskeptic.com/schemas/openai-function-tool-call-item-v1.schema.json"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
