{
  "$id": "https://workflow-verifier/schemas/assurance-manifest-v1.schema.json",
  "title": "AssuranceManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scenarios"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "argv"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "const": "spawn_argv" },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
