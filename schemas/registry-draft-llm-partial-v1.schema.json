{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentskeptic.com/schemas/registry-draft-llm-partial-v1.schema.json",
  "title": "RegistryDraftLlmPartialV1",
  "description": "Model output for registry draft only. Server adds schemaVersion, quickIngestInput, readiness, generation. Full tools rows are validated via tools-registry.schema.json post-merge.",
  "type": "object",
  "additionalProperties": false,
  "required": ["draft", "assumptions", "warnings", "disclaimer", "model"],
  "properties": {
    "draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tools"],
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["toolId", "effectDescriptionTemplate", "verification"],
            "properties": {
              "toolId": { "type": "string", "minLength": 1 },
              "effectDescriptionTemplate": { "type": "string" },
              "verification": {
                "type": "object",
                "required": ["kind"],
                "minProperties": 1,
                "properties": {
                  "kind": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "disclaimer": { "type": "string", "minLength": 1 },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model"],
      "properties": {
        "model": { "type": "string", "minLength": 1 }
      }
    }
  }
}
