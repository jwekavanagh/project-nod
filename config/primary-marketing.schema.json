{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentskeptic.local/primary-marketing.schema.json",
  "title": "Primary marketing SSOT",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "slug",
    "identityOneLiner",
    "productionCanonicalOrigin",
    "gitRepositoryUrl",
    "gitRepositoryGitUrl",
    "npmPackageUrl",
    "bugsUrl",
    "keywords",
    "visitorProblemAnswer",
    "heroTitle",
    "heroSubtitle",
    "homepageAcquisitionCtaLabel",
    "pageMetadata",
    "sections",
    "llms",
    "readmeFold",
    "readmeTitle",
    "homepageHero",
    "homepageDecisionFraming",
    "problemIndex",
    "cliFollowupLines",
    "shareableTerminalDemo",
    "r2",
    "site",
    "evaluator",
    "buyerFit",
    "homeWhatCatches",
    "mechanism"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "slug": { "type": "string", "const": "/database-truth-vs-traces" },
    "identityOneLiner": { "type": "string", "minLength": 20 },
    "productionCanonicalOrigin": { "type": "string", "minLength": 8 },
    "gitRepositoryUrl": { "type": "string", "minLength": 8 },
    "gitRepositoryGitUrl": { "type": "string", "minLength": 8 },
    "npmPackageUrl": { "type": "string", "minLength": 8 },
    "bugsUrl": { "type": "string", "minLength": 8 },
    "keywords": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "visitorProblemAnswer": {
      "type": "string",
      "minLength": 200,
      "allOf": [
        { "pattern": "[Rr]ead-?\\s*[Oo]nly" },
        { "pattern": "[Ss][Qq][Ll]" },
        { "pattern": "[Tt]race|[Tt]ool|[Ww]orkflow|[Aa]gent|[Ss]uccess\\s+flag" },
        { "pattern": "[Dd]atabase|[Rr]ow|[Pp]ersisted|[Ss]tate" },
        { "pattern": "[Ss]tructured.{0,80}[Tt]ool|[Tt]ool.{0,80}[Aa]ctivit" },
        { "pattern": "[Vv]erification\\s+time|[Aa]t\\s+verification" }
      ]
    },
    "heroTitle": { "type": "string", "minLength": 1 },
    "heroSubtitle": { "type": "string", "minLength": 1 },
    "homepageAcquisitionCtaLabel": { "type": "string", "minLength": 8 },
    "readmeTitle": {
      "type": "string",
      "minLength": 12,
      "pattern": "^[^#\\n]+$"
    },
    "homepageHero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["what", "why", "when"],
      "properties": {
        "what": { "type": "string", "minLength": 40 },
        "why": { "type": "string", "minLength": 40 },
        "when": { "type": "string", "minLength": 40 }
      }
    },
    "homepageDecisionFraming": {
      "type": "string",
      "minLength": 80,
      "maxLength": 500,
      "allOf": [
        { "pattern": "[Rr]ead-?\\s*[Oo]nly" },
        { "pattern": "([Ss][Qq][Ll]|[Rr]egistr|[Vv]erif)" },
        { "pattern": "[Dd]atabase|[Rr]ow|[Pp]ersisted|[Ss]tate|[Tt]able|[Vv]ector" },
        { "pattern": "[Tt]race|[Ll]og|[Ss]uccess|[Ww]orkflow|[Aa]gent|[Aa]utomation" },
        { "pattern": "[Vv]erification\\s+time|[Aa]t\\s+verification|[Bb]efore\\s+you" }
      ]
    },
    "r2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frameworkMaturity"],
      "properties": {
        "frameworkMaturity": {
          "type": "string",
          "minLength": 20,
          "pattern": "([Cc]rew[AI]{2}|[Aa]uto[Gg]en|[Ee]xperimental)"
        }
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "integrate",
        "openGraph",
        "pricing",
        "home",
        "security",
        "support",
        "claim"
      ],
      "properties": {
        "integrate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "description"],
          "properties": {
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 40 }
          }
        },
        "openGraph": {
          "type": "object",
          "additionalProperties": false,
          "required": ["image"],
          "properties": {
            "image": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "width", "height", "alt"],
              "properties": {
                "path": { "type": "string" },
                "width": { "type": "integer" },
                "height": { "type": "integer" },
                "alt": { "type": "string", "minLength": 10 }
              }
            }
          }
        },
        "pricing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["heroTitle", "positioning", "subtitle"],
          "properties": {
            "heroTitle": { "type": "string" },
            "positioning": { "type": "string" },
            "subtitle": { "type": "string" }
          }
        },
        "home": {
          "type": "object",
          "additionalProperties": false,
          "required": ["heroShortTagline"],
          "properties": {
            "heroShortTagline": { "type": "string", "minLength": 20 }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "description"],
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "support": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "description"],
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "claim": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "description"],
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sectionTitle",
        "whatWeCheckHeading",
        "whatWeCheck",
        "whatEvidenceHeading",
        "whatEvidence",
        "whatWeDoNotProveHeading",
        "whatWeDoNotProve",
        "quickVsContract",
        "crossingCanonicalSentence",
        "antiSubstitutionOneLiner",
        "integrateCtaLabel",
        "integrateHref"
      ],
      "properties": {
        "sectionTitle": { "type": "string" },
        "whatWeCheckHeading": { "type": "string" },
        "whatWeCheck": { "type": "string", "minLength": 20 },
        "whatEvidenceHeading": { "type": "string" },
        "whatEvidence": { "type": "string" },
        "whatWeDoNotProveHeading": { "type": "string" },
        "whatWeDoNotProve": { "type": "string" },
        "quickVsContract": { "type": "string" },
        "crossingCanonicalSentence": { "type": "string" },
        "antiSubstitutionOneLiner": { "type": "string" },
        "integrateCtaLabel": { "type": "string" },
        "integrateHref": { "type": "string", "pattern": "^/integrate$" }
      }
    },
    "buyerFit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forYou", "notForYou"],
      "properties": {
        "forYou": { "type": "array", "minItems": 3, "maxItems": 6, "items": { "type": "string" } },
        "notForYou": { "type": "array", "minItems": 3, "maxItems": 6, "items": { "type": "string" } }
      }
    },
    "homeWhatCatches": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sectionTitle", "bullets"],
      "properties": {
        "sectionTitle": { "type": "string" },
        "bullets": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "intro", "items", "notObservability"],
      "properties": {
        "title": { "type": "string" },
        "intro": { "type": "string" },
        "items": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "notObservability": { "type": "string" }
      }
    },
    "problemIndex": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["moment", "primaryRoute"],
        "properties": {
          "moment": { "type": "string", "minLength": 12 },
          "primaryRoute": {
            "type": "string",
            "pattern": "^/(guides|examples|compare)/[a-z0-9-]+$"
          },
          "relatedRoutes": {
            "type": "array",
            "maxItems": 6,
            "items": {
              "type": "string",
              "pattern": "^/(guides|examples|compare)/[a-z0-9-]+$|^/(integrate|pricing|database-truth-vs-traces)$"
            }
          }
        }
      }
    },
    "cliFollowupLines": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 220
      }
    },
    "pageMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": {
          "type": "string",
          "minLength": 120,
          "maxLength": 320,
          "allOf": [
            { "pattern": "[Rr]ead-?\\s*[Oo]nly" },
            { "pattern": "([Ss][Qq][Ll]|[Pp]ersist|[Ss]tate)" },
            { "pattern": "[Tt]race|[Tt]ool|[Ww]orkflow|[Aa]gent|[Ss]uccess\\s+flag" },
            { "pattern": "[Dd]atabase|[Rr]ow|[Pp]ersisted|[Ss]tate" },
            { "pattern": "[Vv]erification\\s+time|[Aa]t\\s+verification|[Tt]ool" }
          ]
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "paragraphs"],
        "properties": {
          "heading": { "type": "string", "minLength": 1 },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "llms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intentPhrases", "notFor", "relatedQueries"],
      "properties": {
        "intentPhrases": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "notFor": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "relatedQueries": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "readmeFold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateLines"],
      "properties": {
        "templateLines": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 0 }
        }
      }
    },
    "shareableTerminalDemo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "transcript"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 8,
          "maxLength": 120
        },
        "transcript": {
          "type": "string",
          "minLength": 100,
          "maxLength": 6000,
          "not": { "pattern": "```" },
          "allOf": [
            { "pattern": "wf_complete" },
            { "pattern": "wf_missing" },
            { "pattern": "ROW_ABSENT" }
          ]
        }
      }
    }
  }
}
