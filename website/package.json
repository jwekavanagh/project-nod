{
  "name": "agentskeptic-web",
  "version": "1.1.3",
  "private": true,
  "engines": {
    "node": "22.x || 24.x"
  },
  "scripts": {
    "prebuild": "node ../scripts/sync-website-ssot.mjs",
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "db:generate": "node ./scripts/drizzle-kit-guarded.mjs generate",
    "db:generate:telemetry": "node ./scripts/drizzle-kit-guarded.mjs generate --config drizzle.telemetry.config.ts",
    "db:migrate": "node ./scripts/db-migrate.mjs",
    "db:migrate:telemetry": "node ./scripts/db-migrate-telemetry.mjs",
    "check:docs-claim-urls": "node ../scripts/check-docs-claim-urls.mjs",
    "sql:eval-to-account-staging-gates": "node ./scripts/sql-eval-to-account-staging-gates.mjs",
    "verify:eval-to-account-gate:mechanical": "npm run check:docs-claim-urls && npm run sql:eval-to-account-staging-gates -- --gate-set=rr",
    "verify:eval-to-account-gate": "npx vitest run __tests__/oss-claim.integration.test.ts && npm run verify:eval-to-account-gate:mechanical",
    "test:vitest": "node ../scripts/sync-website-ssot.mjs && node ./scripts/prepare-vitest-databases.mjs && vitest run"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@auth/drizzle-adapter": "1.11.1",
    "@vercel/analytics": "^2.0.1",
    "agentskeptic": "file:..",
    "drizzle-orm": "0.45.2",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "8.0.5",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "postcss": "8.5.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cheerio": "^1.0.0",
    "drizzle-kit": "0.31.10",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.1",
    "tar": "7.5.13",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
