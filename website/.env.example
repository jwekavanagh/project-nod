# Local: no sslmode (localhost is not auto-upgraded). Hosted Supabase / Vercel: sslmode=require on DATABASE_URL
# (app: ensureSslModeRequire). drizzle-kit migrate uses node-pg — drizzle.config adds uselibpqcompat=true for non-localhost URLs.
# Example Supabase: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/wfv_commercial
# Second Postgres (different database on same instance is fine) for telemetry-tier funnel + product-activation.
TELEMETRY_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/wfv_telemetry
# Set to 1 so anonymous funnel beacons write to TELEMETRY_DATABASE_URL (matches CI / production cutover).
AGENTSKEPTIC_TELEMETRY_WRITES_TELEMETRY_DB=1
# Required for `next build`, production, and CI. Optional for local `npm run dev` (insecure fallback + console warning).
AUTH_SECRET=generate_a_long_random_string_at_least_32_chars
NEXTAUTH_SECRET=${AUTH_SECRET}
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Auth.js (Vercel Production): set to the same public origin as NEXT_PUBLIC_APP_URL so session/magic-link
# URLs are not derived from the default deployment host. Optional locally; production should set explicitly.
# AUTH_URL=https://agentskeptic.com
# Bare email only (required for next dev / next build). Regex after trim: /^[^\s@]+@[^\s@]+\.[^\s@]+$/
CONTACT_SALES_EMAIL=kavanagh.james@ymail.com
# Resend: production must use EMAIL_FROM on a domain you verify at https://resend.com/domains
# Using onboarding@resend.dev only works for development: Resend then accepts recipients that match
# the mailbox tied to your Resend account (other addresses return 403). Fix by verifying DNS and
# setting EMAIL_FROM to e.g. "AgentSkeptic <auth@your-verified-domain.com>".
EMAIL_FROM="AgentSkeptic <onboarding@resend.dev>"
RESEND_API_KEY=re_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Base (licensed) recurring — monthly; first id is default for new Checkout. Optional comma/space list for rotation.
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_BUSINESS=price_...
# Optional annual (20% off vs monthly ×12 in config); used when checkout sends interval=yearly.
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_...
STRIPE_PRICE_TEAM_YEARLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
# Metered overage (per verification) — second Checkout line item; see scripts/stripe-bootstrap.mjs
STRIPE_OVERAGE_INDIVIDUAL=price_...
STRIPE_OVERAGE_TEAM=price_...
STRIPE_OVERAGE_BUSINESS=price_...
# Secures POST/GET /api/internal/usage/overage-reconcile (Vercel Cron sends Authorization: Bearer)
CRON_SECRET=generate_a_long_random_string
# E2E only — never in production:
# E2E_COMMERCIAL_FUNNEL=1
# RESERVE_EMERGENCY_ALLOW=1

# Optional: same-origin POST /api/integrator/registry-draft (see docs/registry-draft.md). Requires OpenAI.
# REGISTRY_DRAFT_ENABLED=1
# OPENAI_API_KEY=sk-...
# REGISTRY_DRAFT_MODEL=gpt-4o-mini
