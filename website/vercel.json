{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "NEXT_IGNORE_INCORRECT_LOCKFILE": "1"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/internal/usage/overage-reconcile",
      "schedule": "0 */4 * * *"
    }
  ]
}
