{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd .. && npm ci",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/internal/usage/overage-reconcile",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/internal/trust-alerts",
      "schedule": "5 0 * * *"
    }
  ]
}
